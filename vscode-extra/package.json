{
  "name": "vscode-extra",
  "displayName": "vscode-extra",
  "description": "AI workspace assistant for vibe coders",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.118.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:vscode-extra-sidebar"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "vscode-extra",
          "title": "VS Extra",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "vscode-extra": [
        {
          "type": "webview",
          "id": "vscode-extra-sidebar",
          "name": "AI Assistant"
        }
      ]
    },
    "commands": [
      {
        "command": "vscode-extra.helloWorld",
        "title": "Hello World"
      }
    ]
    ,
    "configuration": {
      "type": "object",
      "title": "VS Code Extra",
      "properties": {
        "vscode-extra.geminiApiKey": {
          "type": "string",
          "default": "",
          "description": "Gemini API key used for VS Code Extra AI assistant."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.118.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "webpack": "^5.105.3",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "@vscode/webview-ui-toolkit": "^1.4.0"
    ,
    "@google/generative-ai": "^0.2.0"
  }
}
